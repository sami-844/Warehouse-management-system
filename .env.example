# Database password - use a strong random password
DB_PASSWORD=change_this_to_a_strong_password_min_20_chars

# Secret key for JWT tokens - use a long random string
SECRET_KEY=change_this_to_a_very_long_random_secret_key_min_32_chars

# These stay the same
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=*
DEBUG=False
