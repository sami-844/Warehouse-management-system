# Warehouse Management System - Environment Configuration
# Copy this to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/warehouse_db
# For SQLite testing: DATABASE_URL=sqlite:///./warehouse.db

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=Warehouse Management System
APP_VERSION=1.0.0
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Redis (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# Email (optional - for notifications)
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-password
MAIL_FROM=noreply@warehouse.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False

# Company Information
COMPANY_NAME=AK Al Momaiza Trading
COMPANY_ADDRESS=Oman
COMPANY_PHONE=+968-XXXXXXXX
COMPANY_EMAIL=info@akalmomiaiza.com
CURRENCY=OMR
